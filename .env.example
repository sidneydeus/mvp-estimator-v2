NODE_ENV=development
PORT=3000

# Provedor de IA (mock ou openai-compatible)
AI_PROVIDER=mock

# Configurações para provedores compatíveis com OpenAI (OpenAI, Groq, Gemini, xAI, etc)
# AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_key_here
AI_MODEL=gpt-4o-mini

# Custos por 1M de tokens (usados para o cálculo financeiro da estimativa)
AI_INPUT_COST_PER_1M_TOKENS=0.15
AI_OUTPUT_COST_PER_1M_TOKENS=0.60

# --- Exemplos de outros provedores ---

# Groq:
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=your_groq_key_here
# AI_MODEL=llama-3.3-70b-versatile

# Google Gemini:
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AI_API_KEY=your_gemini_key_here
# AI_MODEL=gemini-1.5-flash

# xAI/Grok:
# AI_BASE_URL=https://api.x.ai/v1
# AI_API_KEY=your_xai_key_here
# AI_MODEL=grok-beta
